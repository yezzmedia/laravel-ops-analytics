{
    "name": "yezzmedia/laravel-ops-analytics",
    "version": "0.1.1",
    "description": "Ops-facing analytics delivery posture, tracker health, and consent-aware dispatch package for the Yezz Media Laravel platform.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.92",
        "yezzmedia/laravel-foundation": "^0.1.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "YezzMedia\\OpsAnalytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YezzMedia\\OpsAnalytics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YezzMedia\\OpsAnalytics\\OpsAnalyticsServiceProvider"
            ]
        },
        "pest": {
            "plugins": [
                "Pest\\Laravel\\Plugin"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G src tests",
        "format": "vendor/bin/pint --format agent"
    },
    "suggest": {
        "spatie/laravel-activitylog": "Required to persist analytics audit entries via activity logs.",
        "yezzmedia/laravel-user-consent": "Adds consent-aware dispatch gating integration.",
        "yezzmedia/laravel-ops": "Adds the shared ops panel shell that can load this package's Filament plugin."
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
